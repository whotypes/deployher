DATABASE_URL=postgresql://app:app@localhost:5432/placeholder
APP_ENV=development
HOSTNAME=0.0.0.0
PORT=3000
DEV_DOMAIN=localhost
PROD_DOMAIN=localhost
DEV_PROTOCOL=http
PROD_PROTOCOL=https
REDIS_URL=redis://localhost:6379
S3_ENDPOINT=http://127.0.0.1:3900
BUILD_WORKDIR=/tmp/pdploy-builds
BUILD_WORKERS=0
BUILD_CONTAINER_MEMORY=1g
BUILD_CONTAINER_CPUS=0.5
BUILD_NODE_IMAGE=node:22-bookworm
BUILD_BUN_IMAGE=oven/bun:1
BUILD_PYTHON_IMAGE=python:3.12-bookworm
RUNTIME_STATIC_BASE_IMAGE=nginx:alpine

# Region
S3_REGION=garage
# Run infra/.dev.sh to inject these
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

BETTER_AUTH_URL=
# Run openssl rand -base64 32
BETTER_AUTH_SECRET=

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
