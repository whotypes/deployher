DATABASE_URL=postgresql://app:app@localhost:5432/placeholder
APP_ENV=development
HOSTNAME=0.0.0.0
PORT=3000
DEV_DOMAIN=localhost
PROD_DOMAIN=localhost
DEV_PROTOCOL=http
PROD_PROTOCOL=https
REDIS_URL=redis://localhost:6379
S3_ENDPOINT=http://127.0.0.1:3900
BUILD_WORKDIR=/tmp/pdploy-builds
BUILD_WORKERS=0
BUILD_ACCOUNT_MAX_CONCURRENT=1
BUILD_ACCOUNT_SLOT_TTL_SECONDS=21600
BUILD_RECLAIM_IDLE_MS=900000
BUILD_PENDING_HEARTBEAT_MS=30000
BUILD_CONTAINER_MEMORY=1g
BUILD_CONTAINER_CPUS=0.5
BUILD_NODE_IMAGE=localhost:8082/node:22-bookworm
BUILD_BUN_IMAGE=localhost:8082/oven/bun:1
BUILD_PYTHON_IMAGE=localhost:8082/python:3.12-bookworm
RUNTIME_STATIC_BASE_IMAGE=localhost:8082/nginx:alpine

# Region
S3_REGION=garage
# Nexus Docker registry (for dev.sh to auto-login). Leave empty to skip.
NEXUS_REGISTRY=
NEXUS_USER=
NEXUS_PASSWORD=

# Run infra/.dev.sh to inject these
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

BETTER_AUTH_URL=
# Run openssl rand -base64 32
BETTER_AUTH_SECRET=

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
