DATABASE_URL=postgresql://app:app@localhost:5432/placeholder
APP_ENV=development
HOSTNAME=0.0.0.0
PORT=3001
DEV_DOMAIN=localhost
PROD_DOMAIN=localhost
DEV_PROTOCOL=http
PROD_PROTOCOL=https
REDIS_URL=redis://localhost:6379
S3_ENDPOINT=http://127.0.0.1:3900
BUILD_WORKDIR=/tmp/pdploy-builds
BUILD_WORKERS=0
BUILD_ACCOUNT_MAX_CONCURRENT=4
BUILD_ACCOUNT_SLOT_TTL_SECONDS=21600
BUILD_RECLAIM_IDLE_MS=5000
BUILD_PENDING_HEARTBEAT_MS=30000
# Kill build commands only after 5m of silence. Increase for slow/native-heavy installs; set <=0 to disable.
BUILD_COMMAND_INACTIVITY_TIMEOUT_MS=300000
BUILD_CONTAINER_MEMORY=1g
BUILD_CONTAINER_CPUS=0.5
BUILD_NODE_IMAGE=localhost:8082/node:22-bookworm
BUILD_NODE_BUILDER_IMAGE=
BUILD_BUN_IMAGE=localhost:8082/pdploy-bun-build-image:latest
BUILD_BUN_BUILDER_IMAGE=
BUILD_PYTHON_IMAGE=localhost:8082/python:3.12-bookworm
RUNTIME_STATIC_BASE_IMAGE=nginx:alpine

# Region
S3_REGION=garage
# Nexus: set all three (non-empty) for ./infra/dev.sh to sync base images into the local registry.
# If any are empty, image sync is skipped but docker build may still use localhost:8082 and fail.
NEXUS_REGISTRY=localhost:8082
NEXUS_USER=admin
NEXUS_PASSWORD=changeme123!

# Run infra/.dev.sh to inject these
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

BETTER_AUTH_URL=http://localhost:3001
# openssl rand -base64 32 — set in dev; required for production
BETTER_AUTH_SECRET=

# Required for app startup (GitHub OAuth). Callback: http://localhost:3001 or :3000 + /api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
