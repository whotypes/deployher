# Slim .env: Docker Compose ${VAR} overrides + secrets not committed elsewhere.
# Full defaults and tunables: config/default.toml (copy config/local.example.toml → config/local.toml for overrides).
#
# Compose hardcodes in-container RUNNER_URL and PREVIEW_RUNTIME_REGISTRY (preview-runner / workers).
# Keep localhost URLs here for host tools (migrate, CLI, docker login to Nexus on the host).
# For `bun dev` on the host, point at the preview runner (same port as RUNNER_PORT is typical). In Compose, services override this.
# Optional: RUNNER_PREVIEW_ENABLED=0 to disable server previews without removing RUNNER_URL.
RUNNER_PREVIEW_ENABLED=
RUNNER_URL=http://127.0.0.1:8787
RUNNER_SHARED_SECRET=

# --- optional: override docker-compose.yml ${VAR:-defaults} ---
# Regenerate keys only: bun run config:write-dotenv
BUILD_WORKERS=
NEXUS_REGISTRY=
# optional: registry prefix for deployher-node/bun builders + python (Nexus, ECR). Omit for local Docker tags from compose build.
BUILD_IMAGE_REGISTRY=
# optional: override bun build container image. Omit to use deployher-bun-build-image (with npm). Do not set to oven/bun if installs run npm in lifecycle scripts.
# BUILD_BUN_IMAGE=
PREVIEW_TTL_MS=
PREVIEW_MEMORY_BYTES=
PREVIEW_NANO_CPUS=
# Preview runtime image registry host for docker push/pull (worker + preview-runner). The Docker *daemon*
# resolves this (host DNS), not compose — default in compose is 127.0.0.1:8082 when Nexus publishes 8082.
# PREVIEW_RUNTIME_DOCKER_DAEMON_REGISTRY=host.docker.internal:8082
PREVIEW_RUNTIME_REGISTRY=
PREVIEW_RUNTIME_DOCKER_DAEMON_REGISTRY=
PREVIEW_RUNTIME_DOCKER_REPO=
PREVIEW_RUNTIME_IMAGE_NAME=
# preview-runner: docker pull auth (no docker CLI in image). Default serveraddress is http://<PREVIEW_RUNTIME_REGISTRY>.
# PREVIEW_RUNTIME_REGISTRY_HTTPS=1
# PREVIEW_RUNTIME_REGISTRY_AUTH_ADDRESS=https://nexus.example.com:8082
PREVIEW_RUNNER_IMAGE_GC_INTERVAL_MS=
PREVIEW_RUNNER_IMAGE_MAX_AGE_MS=

# --- secrets & credentials (required for real use) ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Optional: override device-flow CLI id (must match `deployher login` client_id). Default: deployher-cli
# DEPLOYHER_CLI_CLIENT_ID=
# Optional: default API origin for `deployher login` when no URL argument is passed
# DEPLOYHER_API_URL=http://localhost:3000
# Optional: PAT for live GitHub tests (automation only; the app uses per-user OAuth tokens on the server).
GITHUB_TEST_TOKEN=
# Set to 1 with GITHUB_TEST_TOKEN to run src/lib/githubRepoLocs.integration.test.ts (skipped by default).
GITHUB_INTEGRATION_TESTS=
BETTER_AUTH_SECRET=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
NEXUS_USER=
NEXUS_PASSWORD=

# Optional: per-preview traffic sampling (0–1). Client IP for observability uses X-Forwarded-For (first hop) when plausible.
# PREVIEW_TRAFFIC_SAMPLE_RATE=0.02
# QUEUE_STALL_CHECK_INTERVAL_MS=60000

# Optional: TCP origin for site-metadata fetch (preview HTML). Unset by default — for *.localhost
# previews the app tries the public URL, then 127.0.0.1, app (Compose), and host.docker.internal with
# the same Host header. Override only if you need a custom gateway.
# SITE_META_FETCH_ORIGIN=http://host.docker.internal:3000
# SITE_META_FETCH_TIMEOUT_MS=10000
# SITE_META_MAX_HTML_BYTES=786432
# Max bytes when proxying OG/icon images for the project hero (default 8388608).
# SITE_PREVIEW_IMAGE_MAX_BYTES=8388608

# Vite dev (`bun run dev:vite`): where to proxy /api and /assets. Defaults to http://127.0.0.1:${PORT}
# with PORT from this file, or 3001 (same default as config/default.toml). Set explicitly if the API
# runs on another host/port (e.g. Docker mapping).
# VITE_DEV_API_URL=http://127.0.0.1:3000
